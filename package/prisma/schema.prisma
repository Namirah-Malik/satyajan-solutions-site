generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Product {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  name             String
  SKU              String
  description      String
  price            Float
  images           String[]
  video            String?
  slug             String?
  tags             String[]   // ← NEW: product tags/keywords
  salient_features String[]
  features         String[]
  specifications   Json[]
  data             Json[]
  category         String?
}
