// prisma/schema.prisma
// ── CHANGES: Added `slug` field for SEO-friendly URLs ────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Product {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  name             String
  SKU              String
  description      String
  price            Float
  images           String[]
  video            String?

  // ── NEW: SEO slug field ───────────────────────────────────────────────────
  // Run `npx ts-node scripts/generate-slugs.ts` after adding this field
  // Then run: npx prisma generate && npx prisma db push
 slug             String?  @unique

  salient_features String[]
  features         String[]
  specifications   Json[]
  data             Json[]
  category         String?
}
